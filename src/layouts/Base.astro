---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'The Fourth Angle', description = 'Daily bite-size clarity for smarter thinking and better questions.' } = Astro.props;
const siteUrl = Astro.site?.origin || 'https://thefourthangle.pages.dev';
const canonicalUrl = `${siteUrl}${Astro.url.pathname === '/' ? '/' : Astro.url.pathname}`;
const ogImage = `${siteUrl}/og-image.png`;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta name="theme-color" content="#F8F9FA" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:type" content="image/png" />
  <meta property="og:image:alt" content={`${title} — Non-partisan Malaysian issues platform`} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="The Fourth Angle" />
  <meta property="og:locale" content="en_MY" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:site" content="@fourthangle" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />
  <meta name="twitter:image:alt" content={`${title} — Non-partisan Malaysian issues platform`} />
  <link rel="canonical" href={canonicalUrl} />
  <meta name="mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <link rel="manifest" href="/manifest.json" />
  <link rel="icon" type="image/png" href="/favicon.png?v=2" />
  <link rel="apple-touch-icon" href="/icons/icon-192.png" />
</head>
<body>
  <a href="#main-content" class="sr-only">Skip to content</a>
  <div id="main-content">
    <slot />
  </div>
  <script>
    if ('serviceWorker' in navigator) {
      navigator.serviceWorker.register('/sw.js').catch(() => {});
    }
  </script>
</body>
</html>
