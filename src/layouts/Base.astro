---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'The Fourth Angle — Bite-Sized Malaysian Issues Analysis', description = 'Bite-size clarity for smarter thinking and better questions. The strongest check on power is a public that reads.' } = Astro.props;
const siteUrl = Astro.site?.origin || 'https://thefourthangle.pages.dev';
const canonicalPath = Astro.url.pathname
  .replace(/index\.html$/, '')
  .replace(/\.html$/, '') || '/';
const canonicalUrl = `${siteUrl}${canonicalPath === '/' ? '/' : canonicalPath}`;
const buildId = typeof __BUILD_ID__ !== 'undefined' ? __BUILD_ID__ : new Date().toISOString();
const commitSha = typeof __COMMIT_SHA__ !== 'undefined' ? __COMMIT_SHA__ : 'unknown';
const ogImage = `${siteUrl}/og-image.png?v=${encodeURIComponent(buildId)}`;
---
<!DOCTYPE html>
<html lang="en" prefix="og: https://ogp.me/ns#">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta name="color-scheme" content="light dark" />
  <meta name="HandheldFriendly" content="true" />
  <meta name="MobileOptimized" content="320" />
  <meta name="theme-color" content="#F8F9FA" media="(prefers-color-scheme: light)" />
  <meta name="theme-color" content="#1A1A1A" media="(prefers-color-scheme: dark)" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:secure_url" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:type" content="image/png" />
  <meta property="og:image:alt" content={`${title} — Independent Malaysian issues analysis`} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="The Fourth Angle" />
  <meta property="og:locale" content="en_MY" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:site" content="@fourthangle" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />
  <meta name="twitter:image:alt" content={`${title} — Independent Malaysian issues analysis`} />
  <meta name="author" content="The Fourth Angle" />
  <link rel="canonical" href={canonicalUrl} />
  <meta name="mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <meta name="application-name" content="The Fourth Angle" />
  <meta name="apple-mobile-web-app-title" content="4th Angle" />
  <meta name="format-detection" content="telephone=no" />
  <link rel="manifest" href={`/manifest.json?v=${encodeURIComponent(buildId)}`} />
  <link rel="icon" type="image/svg+xml" href={`/favicon.svg?v=${encodeURIComponent(buildId)}`} />
  <link rel="icon" type="image/png" href={`/favicon.png?v=${encodeURIComponent(buildId)}`} />
  <link rel="apple-touch-icon" href={`/icons/apple-touch-icon.png?v=${encodeURIComponent(buildId)}`} />
</head>
<body data-build-id={buildId} data-commit-sha={commitSha}>
  <a href="#main-content" class="sr-only">Skip to content</a>
  <div id="main-content" tabindex="-1">
    <slot />
  </div>
  <script is:inline define:vars={{ buildId, commitSha }}>
    window.__TFA_RELEASE__ = { buildId, commitSha };
    if ('serviceWorker' in navigator) {
      const currentBuild = String(buildId);
      const priorBuild = sessionStorage.getItem('tfa-sw-build');
      let reloading = false;

      navigator.serviceWorker.addEventListener('controllerchange', () => {
        if (!priorBuild || priorBuild === currentBuild || reloading) {
          sessionStorage.setItem('tfa-sw-build', currentBuild);
          return;
        }
        reloading = true;
        sessionStorage.setItem('tfa-sw-build', currentBuild);
        location.reload();
      });

      window.addEventListener('load', () => {
        navigator.serviceWorker
          .register(`/sw.js?v=${encodeURIComponent(currentBuild)}`, { updateViaCache: 'none' })
          .then((registration) => {
            sessionStorage.setItem('tfa-sw-build', currentBuild);
            registration.update().catch(() => {});
          })
          .catch(() => {});
      });
    }
    // Back link: go back if history exists, otherwise go home
    document.querySelector('.back-link')?.addEventListener('click', (e) => {
      e.preventDefault();
      let canGoBack = false;
      try {
        canGoBack = !!document.referrer && new URL(document.referrer).origin === location.origin;
      } catch {}
      if (canGoBack) {
        history.back();
      } else {
        location.href = '/';
      }
    });
    // F02/F03: Crossfade route transition using View Transitions API
    // Progressive enhancement — falls back to instant navigation on unsupported browsers
    if ('startViewTransition' in document) {
      document.addEventListener('click', (e) => {
        const target = e.target;
        if (!(target instanceof Element)) return;
        const anchor = target.closest('a[href]');
        if (!anchor) return;
        const href = anchor.getAttribute('href');
        if (!href || href.startsWith('#') || href.startsWith('http') || href.startsWith('mailto:')) return;
        // Same-origin internal navigation only
        if (anchor.origin !== location.origin) return;
        e.preventDefault();
        document.startViewTransition(() => {
          location.href = href;
        });
      });
    }
  </script>
</body>
</html>
