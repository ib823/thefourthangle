---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'The Fourth Angle — The Real Minority', description = 'Malaysian issues. 6 perspectives. Zero partisan bias.' } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta name="theme-color" content="#F8F9FA" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta property="og:title" content="The Fourth Angle — The Real Minority" />
  <meta property="og:description" content="Malaysian issues. 6 perspectives. Zero partisan bias." />
  <meta property="og:image" content="https://thefourthangle.pages.dev/og-image.png" />
  <meta property="og:url" content="https://thefourthangle.pages.dev/" />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="The Fourth Angle" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="The Fourth Angle — The Real Minority" />
  <meta name="twitter:description" content="Malaysian issues. 6 perspectives. Zero partisan bias." />
  <meta name="twitter:image" content="https://thefourthangle.pages.dev/og-image.png" />
  <link rel="canonical" href="https://thefourthangle.pages.dev/" />
  <meta name="mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <link rel="manifest" href="/manifest.json" />
  <link rel="icon" type="image/png" href="/favicon.png?v=2" />
  <link rel="apple-touch-icon" href="/icons/icon-192.png" />
</head>
<body>
  <a href="#main-content" class="sr-only">Skip to content</a>
  <div id="main-content">
    <slot />
  </div>
  <script>
    if ('serviceWorker' in navigator) {
      navigator.serviceWorker.register('/sw.js').catch(() => {});
    }
  </script>
</body>
</html>
