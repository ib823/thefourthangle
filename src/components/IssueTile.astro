---
import type { Issue } from '../lib/types';
import { LENS_META } from '../lib/constants';

interface Props {
  issue: Issue;
}

const { issue } = Astro.props;
const scoreColor = issue.audit.finalScore >= 80 ? '#5B8A3C' : issue.audit.finalScore >= 65 ? '#8B6508' : '#B54A32';
const hookCard = issue.cards.find(c => c.t === 'hook');
const cardCount = issue.cards.length;
const lensColorBg: Record<string, string> = {
  legal: 'rgba(82,82,91,0.08)',
  social: 'rgba(107,76,122,0.08)',
  economic: 'rgba(122,99,50,0.08)',
  historical: 'rgba(139,101,8,0.08)',
  theological: 'rgba(107,91,62,0.08)',
  critical: 'rgba(85,85,85,0.08)',
};
---
<a href={`/issue/${issue.slug}`} style={`display:block;text-decoration:none;color:inherit;background:var(--card);border-radius:22px;padding:24px;box-shadow:0 8px 24px rgba(31,26,20,0.05);border:1px solid var(--border);transition:transform 0.15s ease, box-shadow 0.15s ease;position:relative;`} onmouseenter="this.style.transform='translateY(-1px)';this.style.boxShadow='0 4px 12px rgba(44,34,21,0.1), 0 2px 4px rgba(44,34,21,0.06)';" onmouseleave="this.style.transform='';this.style.boxShadow='';">
  <div style={`position:absolute;top:14px;right:14px;display:flex;flex-direction:column;align-items:center;`}>
    <div style={`width:36px;height:36px;border-radius:50%;background:${scoreColor};display:flex;align-items:center;justify-content:center;`}>
      <span style="font-family:var(--font-display);font-size:12px;font-weight:700;color:white;">{issue.audit.finalScore}</span>
    </div>
    <span style="font-size:8px;color:var(--text-tertiary);margin-top:2px;text-transform:uppercase;letter-spacing:0.05em;">score</span>
  </div>
  <h3 style="font-family:var(--font-display);font-size:22px;font-weight:700;color:var(--text-primary);margin:0 0 8px 0;padding-right:52px;line-height:1.3;">{issue.title}</h3>
  <div style="display:flex;align-items:center;gap:8px;margin-bottom:10px;flex-wrap:wrap;">
    <span style="font-size:12px;color:var(--text-tertiary);">{issue.period}</span>
    <span style="font-size:11px;color:var(--text-tertiary);">·</span>
    <span style="font-size:11px;color:var(--text-tertiary);font-weight:600;">{cardCount} angles</span>
    {issue.lenses.map(lens => {
      const meta = LENS_META[lens];
      const bg = lensColorBg[lens] || 'rgba(44,34,21,0.05)';
      return meta ? (
        <span style={`font-size:10px;text-transform:uppercase;letter-spacing:0.08em;color:${meta.color};background:${bg};padding:3px 8px;border-radius:6px;font-weight:600;`}>{meta.symbol} {meta.label}</span>
      ) : null;
    })}
  </div>
  {hookCard?.sub && (
    <p style="font-size:14px;color:var(--text-secondary);margin:0;line-height:1.5;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">{hookCard.sub}</p>
  )}
</a>
