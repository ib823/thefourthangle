---
interface Props {
  current?: 'about' | 'verify' | 'disclaimer';
}

const { current } = Astro.props;
---

<header class="utility-header">
  <div class="utility-header-inner">
    <a href="/" class="utility-brand" aria-label="The Fourth Angle — go to Today">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="176 350 607 258"
        class="utility-logo"
        aria-hidden="true"
      >
        <path
          d="M 773 363 L 691 363 L 680 366 L 666 378 L 590 542 L 567 595 L 616 595 L 624 574 L 637 547 L 728 547 L 729 595 L 773 595 Z M 727 399 L 729 401 L 729 506 L 656 507 L 655 506 L 698 411 L 703 405 L 709 401 Z M 482 363 L 378 509 L 378 547 L 499 547 L 500 595 L 545 595 L 545 549 L 576 507 L 545 506 L 545 364 Z M 499 412 L 500 506 L 432 507 L 431 506 Z M 186 363 L 186 408 L 273 409 L 273 595 L 318 595 L 318 409 L 391 408 L 422 363 Z"
          fill="currentColor"
          fill-rule="evenodd"
        />
      </svg>
      <span class="utility-wordmark">The Fourth Angle</span>
    </a>

    <button class="nav-hamburger" aria-label="Open menu" aria-expanded="false">
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
    </button>

    <nav class="utility-nav" aria-label="Main navigation">
      <a href="/" class="utility-nav-link">Today</a>
      <a
        href="/about"
        class={`utility-nav-link${current === 'about' ? ' utility-nav-link--active' : ''}`}
        aria-current={current === 'about' ? 'page' : undefined}
      >
        How This Works
      </a>
      <a
        href="/verify"
        class={`utility-nav-link${current === 'verify' ? ' utility-nav-link--active' : ''}`}
        aria-current={current === 'verify' ? 'page' : undefined}
      >
        Verify
      </a>
      <a
        href="/disclaimer"
        class={`utility-nav-link${current === 'disclaimer' ? ' utility-nav-link--active' : ''}`}
        aria-current={current === 'disclaimer' ? 'page' : undefined}
      >
        Disclaimer
      </a>
    </nav>

    <div class="nav-backdrop"></div>
  </div>
</header>

<script>
  const hamburger = document.querySelector('.nav-hamburger');
  const nav = document.querySelector('.utility-nav');
  const backdrop = document.querySelector('.nav-backdrop');

  if (hamburger && nav && backdrop) {
    function openMenu() {
      hamburger!.setAttribute('aria-expanded', 'true');
      hamburger!.setAttribute('aria-label', 'Close menu');
      nav!.classList.add('is-open');
      backdrop!.classList.add('is-visible');
    }

    function closeMenu() {
      hamburger!.setAttribute('aria-expanded', 'false');
      hamburger!.setAttribute('aria-label', 'Open menu');
      nav!.classList.remove('is-open');
      backdrop!.classList.remove('is-visible');
    }

    hamburger.addEventListener('click', (e) => {
      e.stopPropagation();
      hamburger.getAttribute('aria-expanded') === 'true' ? closeMenu() : openMenu();
    });

    nav.querySelectorAll('.utility-nav-link').forEach(link => {
      link.addEventListener('click', closeMenu);
    });

    backdrop.addEventListener('click', closeMenu);

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeMenu();
    });
  }
</script>

<style>
  .utility-header {
    position: sticky;
    top: 0;
    z-index: 40;
    border-bottom: 1px solid var(--border-subtle);
    background: var(--header-bg);
    backdrop-filter: blur(12px);
  }

  .utility-header-inner {
    max-width: 1180px;
    margin: 0 auto;
    padding: 0 18px;
    min-height: 62px;
    display: flex;
    align-items: center;
    gap: 18px;
  }

  .utility-brand {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    min-height: 44px;
    border-radius: var(--radius-lg);
    color: var(--text-primary);
    text-decoration: none;
  }

  .utility-logo {
    width: 46px;
    height: auto;
    display: block;
  }

  .utility-wordmark {
    font-family: var(--font-display);
    font-size: var(--text-reading);
    line-height: 1;
    letter-spacing: -0.03em;
    font-weight: 700;
  }

  /* ── Desktop nav pill ── */
  .utility-nav {
    margin-left: auto;
    display: inline-flex;
    align-items: center;
    gap: 4px;
    border-radius: var(--radius-pill);
    padding: 4px;
    border: 1px solid var(--border-subtle);
    background: rgba(255, 255, 255, 0.56);
  }

  .utility-nav-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 36px;
    padding: 0 14px;
    border-radius: var(--radius-pill);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--text-secondary);
    text-decoration: none;
    transition:
      background var(--duration-fast, 150ms) ease,
      color var(--duration-fast, 150ms) ease;
  }

  .utility-nav-link--active {
    color: var(--score-medium);
    background: var(--bg);
  }

  @media (hover: hover) {
    .utility-nav-link:hover {
      color: var(--score-medium);
      background: var(--bg);
    }
  }

  /* ── Hamburger button — hidden on desktop ── */
  .nav-hamburger {
    display: none;
    width: 44px;
    height: 44px;
    margin-left: auto;
    padding: 0;
    border: none;
    background: transparent;
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
    z-index: 60;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 5px;
  }

  .hamburger-line {
    display: block;
    width: 18px;
    height: 1.5px;
    background: var(--text-primary);
    border-radius: 1px;
    transition:
      transform 0.3s cubic-bezier(0.4, 0, 0.2, 1),
      opacity 0.2s ease;
    transform-origin: center;
  }

  /* Hamburger → X animation */
  .nav-hamburger[aria-expanded="true"] .hamburger-line:nth-child(1) {
    transform: translateY(6.5px) rotate(45deg);
  }
  .nav-hamburger[aria-expanded="true"] .hamburger-line:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }
  .nav-hamburger[aria-expanded="true"] .hamburger-line:nth-child(3) {
    transform: translateY(-6.5px) rotate(-45deg);
  }

  /* ── Backdrop overlay — hidden on desktop ── */
  .nav-backdrop {
    display: none;
  }

  /* ── Desktop: hamburger and backdrop never shown ── */
  @media (min-width: 721px) {
    .nav-hamburger { display: none !important; }
    .nav-backdrop { display: none !important; }
  }

  /* ── Mobile & Tablet ≤ 720px ── */
  @media (max-width: 720px) {
    .nav-hamburger {
      display: flex;
    }

    .utility-header-inner {
      min-height: 52px;
      padding: 0 16px;
    }

    .utility-logo {
      width: 38px;
    }

    .utility-wordmark {
      display: none;
    }

    /* Dropdown sheet (closed) */
    .utility-nav {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      margin: 0;
      padding: 6px 0 14px;
      border: none;
      border-radius: 0 0 16px 16px;
      background: var(--bg);
      box-shadow: 0 8px 30px rgba(0, 0, 0, 0.08), 0 1px 3px rgba(0, 0, 0, 0.04);
      z-index: 50;
      display: flex;
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      opacity: 0;
      pointer-events: none;
      clip-path: inset(0 0 100% 0);
      transition:
        opacity 0.25s cubic-bezier(0.4, 0, 0.2, 1),
        clip-path 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    }

    /* Dropdown sheet (open) */
    .utility-nav.is-open {
      opacity: 1;
      pointer-events: auto;
      clip-path: inset(0 0 0 0);
    }

    /* Nav links — spacious, left-aligned */
    .utility-nav-link {
      display: flex;
      align-items: center;
      justify-content: flex-start;
      margin: 2px 12px;
      padding: 12px 14px;
      border-radius: 10px;
      font-size: 0.9375rem;
      font-weight: 500;
      letter-spacing: -0.01em;
      color: var(--text-secondary);
      background: transparent;
    }

    .utility-nav-link:active {
      color: var(--text-primary);
      background: rgba(0, 0, 0, 0.05);
    }

    .utility-nav-link--active {
      color: var(--text-primary);
      font-weight: 600;
    }

    /* Backdrop overlay */
    .nav-backdrop {
      display: block;
      position: fixed;
      inset: 0;
      z-index: 39;
      background: rgba(0, 0, 0, 0.12);
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.25s ease;
    }

    .nav-backdrop.is-visible {
      opacity: 1;
      pointer-events: auto;
    }
  }

  @media (max-width: 720px) and (hover: hover) {
    .utility-nav-link:hover {
      color: var(--text-primary);
      background: rgba(0, 0, 0, 0.03);
    }
  }

  /* ── Dark mode ── */
  @media (prefers-color-scheme: dark) {
    .utility-nav {
      background: rgba(34, 31, 27, 0.7);
    }
  }

  @media (max-width: 720px) and (prefers-color-scheme: dark) {
    .utility-nav {
      background: #1e1c19;
      box-shadow: 0 8px 30px rgba(0, 0, 0, 0.3);
    }

    .utility-nav-link:active {
      background: rgba(255, 255, 255, 0.06);
    }

    .nav-backdrop {
      background: rgba(0, 0, 0, 0.4);
    }
  }
</style>
