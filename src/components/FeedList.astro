---
import IssueTile from './IssueTile.astro';
import NativeAd from './NativeAd.astro';
import type { Issue } from '../lib/types';

const issueFiles = import.meta.glob('../content/issues/*.json', { eager: true });
const issues: Issue[] = Object.values(issueFiles).map((m: any) => m.default || m);
issues.sort((a, b) => new Date(b.publishedAt).getTime() - new Date(a.publishedAt).getTime());
---
<div style="display:flex;flex-direction:column;gap:18px;padding:0 18px;">
  {issues.map((issue, i) => (
    <>
      <IssueTile issue={issue} />
      {i === 1 && <NativeAd />}
    </>
  ))}
</div>
