---
import Base from '../layouts/Base.astro';
import UtilityHeader from '../components/UtilityHeader.astro';
---
<Base title="Disclaimer & Legal Notice — The Fourth Angle" description="Legal disclaimer, editorial standards, and content policies for The Fourth Angle analysis platform.">
  <UtilityHeader current="disclaimer" />
  <main style="max-width:640px;margin:0 auto;padding:24px 18px 80px;">

      <h1 style="font-family:var(--font-display);font-size: var(--text-title-lg);font-weight:700;color:var(--text-primary);margin:0 0 10px 0;letter-spacing:-0.04em;line-height:1.04;">Disclaimer & Legal Notice</h1>
      <p style="font-family:var(--font-body);font-size: var(--text-body);color:var(--text-tertiary);margin:0 0 32px 0;">Last reviewed April 2026</p>

      <!-- Group 1: What We Are -->
      <div style="background:var(--card);border:1px solid var(--border-light);border-radius: var(--radius-lg);padding:20px;margin-bottom:16px;">
        <h2 style="font-family:var(--font-display);font-size: var(--text-reading-lg);font-weight:700;color:var(--text-primary);margin:0 0 12px 0;letter-spacing:-0.03em;">Analysis Platform, Not a News Outlet</h2>
        <p style="font-family:var(--font-body);font-size: var(--text-body);line-height:1.72;color:var(--text-secondary);margin:0;">The Fourth Angle is an independent, non-partisan <strong>analysis platform</strong>. We are not a licensed news outlet, media organisation, or press entity. We publish independent analysis and commentary on matters of public interest based on publicly available information. This platform operates under the Communications and Multimedia Act 1998.</p>
      </div>

      <div style="background:var(--card);border:1px solid var(--border-light);border-radius: var(--radius-lg);padding:20px;margin-bottom:16px;">
        <h2 style="font-family:var(--font-display);font-size: var(--text-reading-lg);font-weight:700;color:var(--text-primary);margin:0 0 12px 0;letter-spacing:-0.03em;">Opinion and Analysis</h2>
        <p style="font-family:var(--font-body);font-size: var(--text-body);line-height:1.72;color:var(--text-secondary);margin:0 0 12px 0;">All content constitutes <strong>analysis, opinion, and commentary</strong>. Content is protected as fair comment on matters of public interest under Malaysian law.</p>
        <p style="font-family:var(--font-body);font-size: var(--text-body);line-height:1.72;color:var(--text-secondary);margin:0;">Factual claims are sourced and cited. Scores and measurements represent our editorial methodology — they are opinions, not objective truth claims.</p>
      </div>

      <div style="background:var(--card);border:1px solid var(--border-light);border-radius: var(--radius-lg);padding:20px;margin-bottom:32px;">
        <h2 style="font-family:var(--font-display);font-size: var(--text-reading-lg);font-weight:700;color:var(--text-primary);margin:0 0 12px 0;letter-spacing:-0.03em;">Good Faith</h2>
        <p style="font-family:var(--font-body);font-size: var(--text-body);line-height:1.72;color:var(--text-secondary);margin:0;">All analysis is published in good faith. We do not intend to defame, harass, threaten, or cause harm. Commentary on public figures is directed at their public actions and policies — not their private lives.</p>
      </div>

      <!-- Group 2: Respect & Sensitivity -->
      <p style="font-family:var(--font-display);font-size: var(--text-xs);font-weight:600;color:var(--text-tertiary);margin:0 0 12px 0;text-transform:uppercase;letter-spacing:0.1em;">Respect & Sensitivity</p>

      <div style="background:var(--card);border:1px solid var(--border-light);border-radius: var(--radius-lg);padding:20px;margin-bottom:16px;">
        <h2 style="font-family:var(--font-display);font-size: var(--text-reading-lg);font-weight:700;color:var(--text-primary);margin:0 0 12px 0;letter-spacing:-0.03em;">Race, Religion, and Royalty</h2>
        <div style="display:flex;flex-direction:column;gap:12px;font-family:var(--font-body);font-size: var(--text-body);line-height:1.72;color:var(--text-secondary);">
          <p style="margin:0;">We respect the equal dignity of all races and ethnic communities. We do not publish content intended to degrade or cause enmity between racial groups.</p>
          <p style="margin:0;">We respect all religions and religious beliefs. We do not intend to insult or attack any religion, religious figure, or institution.</p>
          <p style="margin:0;">We respect the constitutional position of the Malaysian monarchy. We do not advocate for changes to constitutional governance.</p>
          <p style="margin:0;font-style:italic;color:var(--text-tertiary);">We distinguish between critique of public policy and disrespect for communities, beliefs, or institutions. Our mission is to inform — not to divide.</p>
        </div>
      </div>

      <div style="background:var(--card);border:1px solid var(--border-light);border-radius: var(--radius-lg);padding:20px;margin-bottom:32px;">
        <h2 style="font-family:var(--font-display);font-size: var(--text-reading-lg);font-weight:700;color:var(--text-primary);margin:0 0 12px 0;letter-spacing:-0.03em;">Constitutional Framework</h2>
        <p style="font-family:var(--font-body);font-size: var(--text-body);line-height:1.72;color:var(--text-secondary);margin:0;">We respect Malaysia's constitutional framework and rule of law. We do not advocate violence, armed rebellion, or unlawful action. Analysis of government policy supports informed democratic participation.</p>
      </div>

      <!-- Group 3: Accuracy & Limits -->
      <p style="font-family:var(--font-display);font-size: var(--text-xs);font-weight:600;color:var(--text-tertiary);margin:0 0 12px 0;text-transform:uppercase;letter-spacing:0.1em;">Accuracy & Limitations</p>

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:16px;">
        <div style="background:var(--card);border:1px solid var(--border-light);border-radius: var(--radius-lg);padding:16px;">
          <h3 style="font-family:var(--font-display);font-size: var(--text-body);font-weight:700;color:var(--text-primary);margin:0 0 8px 0;">No Accuracy Guarantee</h3>
          <p style="font-family:var(--font-body);font-size: var(--text-ui);line-height:1.6;color:var(--text-secondary);margin:0;">Content is provided "as is." Analysis may contain errors or outdated information despite our review process.</p>
        </div>
        <div style="background:var(--card);border:1px solid var(--border-light);border-radius: var(--radius-lg);padding:16px;">
          <h3 style="font-family:var(--font-display);font-size: var(--text-body);font-weight:700;color:var(--text-primary);margin:0 0 8px 0;">Timeliness</h3>
          <p style="font-family:var(--font-body);font-size: var(--text-ui);line-height:1.6;color:var(--text-secondary);margin:0;">Issues reflect information at time of publication. Each shows its edition number.</p>
        </div>
        <div style="background:var(--card);border:1px solid var(--border-light);border-radius: var(--radius-lg);padding:16px;">
          <h3 style="font-family:var(--font-display);font-size: var(--text-body);font-weight:700;color:var(--text-primary);margin:0 0 8px 0;">Not Professional Advice</h3>
          <p style="font-family:var(--font-body);font-size: var(--text-ui);line-height:1.6;color:var(--text-secondary);margin:0;">Content is not legal, financial, medical, or professional advice. Consult qualified professionals.</p>
        </div>
        <div style="background:var(--card);border:1px solid var(--border-light);border-radius: var(--radius-lg);padding:16px;">
          <h3 style="font-family:var(--font-display);font-size: var(--text-body);font-weight:700;color:var(--text-primary);margin:0 0 8px 0;">External Links</h3>
          <p style="font-family:var(--font-body);font-size: var(--text-ui);line-height:1.6;color:var(--text-secondary);margin:0;">Links to external websites are for reference only. We do not endorse external content.</p>
        </div>
      </div>

      <div style="background:var(--card);border:1px solid var(--border-light);border-radius: var(--radius-lg);padding:20px;margin-bottom:16px;">
        <h2 style="font-family:var(--font-display);font-size: var(--text-reading-lg);font-weight:700;color:var(--text-primary);margin:0 0 12px 0;letter-spacing:-0.03em;">Sources</h2>
        <p style="font-family:var(--font-body);font-size: var(--text-body);line-height:1.72;color:var(--text-secondary);margin:0;">We use only publicly available information. We do not receive, store, or publish material classified under the Official Secrets Act 1972. All sources are disclosed in our published audit for each issue.</p>
      </div>

      <div style="background:var(--card);border:1px solid var(--border-light);border-radius: var(--radius-lg);padding:20px;margin-bottom:16px;">
        <h2 style="font-family:var(--font-display);font-size: var(--text-reading-lg);font-weight:700;color:var(--text-primary);margin:0 0 12px 0;letter-spacing:-0.03em;">Limitation of Liability</h2>
        <p style="font-family:var(--font-body);font-size: var(--text-body);line-height:1.72;color:var(--text-secondary);margin:0;">To the maximum extent permitted by Malaysian law, The Fourth Angle disclaims all liability for damages arising from use of this platform or reliance on its content.</p>
      </div>

      <div style="background:var(--card);border:1px solid var(--border-light);border-radius: var(--radius-lg);padding:20px;margin-bottom:16px;">
        <h2 style="font-family:var(--font-display);font-size: var(--text-reading-lg);font-weight:700;color:var(--text-primary);margin:0 0 12px 0;letter-spacing:-0.03em;">Redistribution and Third-Party Sharing</h2>
        <div style="display:flex;flex-direction:column;gap:12px;font-family:var(--font-body);font-size: var(--text-body);line-height:1.72;color:var(--text-secondary);">
          <p style="margin:0;">Content from The Fourth Angle may be shared for personal, non-commercial purposes. By sharing, forwarding, reposting, screenshotting, or otherwise redistributing any content from this platform — whether through our sharing feature, social media, messaging applications, screenshots, photographs, or any other means — <strong>the redistributor assumes full responsibility</strong> for the context, accuracy, and legality of that redistribution.</p>
          <p style="margin:0;">The Fourth Angle is not liable for any claims, damages, or legal consequences arising from content that has been shared, modified, excerpted, taken out of context, or reproduced by third parties. Shared content reflects the analysis at its original time of publication and may have been corrected or updated since.</p>
          <p style="margin:0;">Each issue carries a verifiable cryptographic signature. Recipients can verify authenticity at <a href="/verify" style="color:var(--focus);text-decoration:none;">thefourthangle.pages.dev/verify</a>. Content that cannot be verified against its original signature should not be treated as authentic.</p>
        </div>
      </div>

      <div style="background:var(--card);border:1px solid var(--border-light);border-radius: var(--radius-lg);padding:20px;margin-bottom:32px;">
        <h2 style="font-family:var(--font-display);font-size: var(--text-reading-lg);font-weight:700;color:var(--text-primary);margin:0 0 12px 0;letter-spacing:-0.03em;">Indemnification</h2>
        <p style="font-family:var(--font-body);font-size: var(--text-body);line-height:1.72;color:var(--text-secondary);margin:0;">By using or redistributing content from this platform, you agree to indemnify, defend, and hold harmless The Fourth Angle, its operators, contributors, and affiliates from and against any claims, liabilities, damages, losses, costs, or expenses (including legal fees) arising from your redistribution, modification, or use of our content in any context.</p>
      </div>

      <!-- Group 4: Standards & Trust -->
      <p style="font-family:var(--font-display);font-size: var(--text-xs);font-weight:600;color:var(--text-tertiary);margin:0 0 12px 0;text-transform:uppercase;letter-spacing:0.1em;">Standards & Trust</p>

      <div style="background:var(--card);border:1px solid var(--border-light);border-radius: var(--radius-lg);padding:20px;margin-bottom:16px;">
        <h2 style="font-family:var(--font-display);font-size: var(--text-reading-lg);font-weight:700;color:var(--text-primary);margin:0 0 12px 0;letter-spacing:-0.03em;">Editorial Review Process</h2>
        <p style="font-family:var(--font-body);font-size: var(--text-body);line-height:1.72;color:var(--text-secondary);margin:0;">Every issue undergoes a 6-stage editorial review: Primary Analysis, Bias Audit, Fact Verification, Alternative Framing, Contrarian Stress-Test, and Synthesis Review. The complete audit is published with every issue. <a href="/about" style="color:var(--focus);text-decoration:none;">Full methodology</a></p>
      </div>

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:16px;">
        <div style="background:var(--card);border:1px solid var(--border-light);border-radius: var(--radius-lg);padding:16px;">
          <h3 style="font-family:var(--font-display);font-size: var(--text-body);font-weight:700;color:var(--text-primary);margin:0 0 8px 0;">Corrections</h3>
          <p style="font-family:var(--font-body);font-size: var(--text-ui);line-height:1.6;color:var(--text-secondary);margin:0;">Errors are corrected in updated editions. Report concerns to <a href="mailto:thefourthangle@proton.me" style="color:var(--focus);text-decoration:none;">thefourthangle@proton.me</a></p>
        </div>
        <div style="background:var(--card);border:1px solid var(--border-light);border-radius: var(--radius-lg);padding:16px;">
          <h3 style="font-family:var(--font-display);font-size: var(--text-body);font-weight:700;color:var(--text-primary);margin:0 0 8px 0;">Authenticity</h3>
          <p style="font-family:var(--font-body);font-size: var(--text-ui);line-height:1.6;color:var(--text-secondary);margin:0;">Every issue carries a cryptographic fingerprint (SHA-256) + Ed25519 signature. <a href="/verify" style="color:var(--focus);text-decoration:none;">Verify content</a></p>
        </div>
      </div>

      <div style="background:var(--card);border:1px solid var(--border-light);border-radius: var(--radius-lg);padding:20px;margin-bottom:16px;">
        <h2 style="font-family:var(--font-display);font-size: var(--text-reading-lg);font-weight:700;color:var(--text-primary);margin:0 0 12px 0;letter-spacing:-0.03em;">Privacy and Data</h2>
        <p style="font-family:var(--font-body);font-size: var(--text-body);line-height:1.72;color:var(--text-secondary);margin:0 0 12px 0;">No user accounts, no tracking, no third-party analytics, no personally identifiable information collected.</p>
        <p style="font-family:var(--font-body);font-size: var(--text-body);line-height:1.72;color:var(--text-secondary);margin:0 0 12px 0;">Your browser's local storage remembers reading progress. By default, this data stays entirely on your device and is never transmitted.</p>
        <p style="font-family:var(--font-body);font-size: var(--text-body);line-height:1.72;color:var(--text-secondary);margin:0 0 12px 0;"><strong style="color:var(--text-primary);">Angle Code (optional sync).</strong> You may choose to generate an anonymous 6-character Angle Code to sync reading progress across devices. If you opt in, the following is stored on our servers: which issues you have opened, your reading position (card 1–7), and which cards you have highlighted. This data is associated only with your Angle Code — not with any name, email, IP address, or other identifier. Sync data is stored on Cloudflare Workers KV with a 90-day expiry and is automatically deleted after that period. You can unlink your device at any time, and your Angle Code can be permanently deleted by contacting thefourthangle@proton.me.</p>
        <p style="font-family:var(--font-body);font-size: var(--text-ui);line-height:1.6;color:var(--text-tertiary);margin:0;">No cookies are used for tracking. Cloudflare (our host) may record standard server logs per their privacy policy.</p>
      </div>

      <div style="background:var(--card);border:1px solid var(--border-light);border-radius: var(--radius-lg);padding:20px;margin-bottom:32px;">
        <h2 style="font-family:var(--font-display);font-size: var(--text-reading-lg);font-weight:700;color:var(--text-primary);margin:0 0 12px 0;letter-spacing:-0.03em;">Independence</h2>
        <p style="font-family:var(--font-body);font-size: var(--text-body);line-height:1.72;color:var(--text-secondary);margin:0;">Independently operated. No political funding, government grants, or payments from any political party, politician, or government-linked entity.</p>
      </div>

      <!-- Footer -->
      <div style="display:flex;flex-direction:column;gap:16px;margin-bottom:28px;">
        <div style="background:var(--amber-bg);border:1px solid rgba(139,101,8,0.12);border-radius: var(--radius-lg);padding:20px;">
          <p style="font-family:var(--font-body);font-size: var(--text-body);line-height:1.72;color:var(--text-secondary);margin:0 0 8px 0;">Governed by the laws of Malaysia. Disputes subject to Malaysian courts.</p>
          <p style="font-family:var(--font-body);font-size: var(--text-ui);line-height:1.6;color:var(--text-tertiary);margin:0;font-style:italic;">Continued use of this platform constitutes acceptance of this disclaimer.</p>
        </div>
        <div style="text-align:center;">
          <p style="font-family:var(--font-body);font-size: var(--text-ui);color:var(--text-tertiary);margin:0 0 4px 0;">Questions, corrections, or legal notices</p>
          <a href="mailto:thefourthangle@proton.me" style="font-family:var(--font-body);font-size: var(--text-body);font-weight:600;color:var(--focus);text-decoration:none;">thefourthangle@proton.me</a>
        </div>
      </div>

  </main>
</Base>
