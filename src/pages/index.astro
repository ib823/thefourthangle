---
import Base from '../layouts/Base.astro';
import App from '../components/App.svelte';
import { readFileSync } from 'node:fs';
import { join } from 'node:path';

// Read pre-built feed summaries (generated by build-issues-json.mjs before astro build)
const feedJson = readFileSync(join(process.cwd(), 'public', 'issues-feed.json'), 'utf8');
const feedData = JSON.parse(feedJson);
---
<Base>
  <App client:load feedData={feedData} />
</Base>
