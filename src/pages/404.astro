---
import Base from '../layouts/Base.astro';

const title = 'Page not found — The Fourth Angle';
const description = 'This page or issue could not be found. Return to Today to continue reading The Fourth Angle.';
---

<Base {title} {description}>
  <main
    style="
      min-height:100vh;
      min-height:100dvh;
      display:flex;
      align-items:center;
      justify-content:center;
      padding:32px 20px;
      background:
        radial-gradient(circle at top right, rgba(210, 140, 40, 0.08), transparent 28%),
        linear-gradient(180deg, var(--bg-elevated) 0%, var(--bg) 22%, var(--bg) 100%);
    "
  >
    <section style="max-width:520px;width:100%;text-align:center;">
      <p style="margin:0;font-size:11px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:var(--text-tertiary);">
        404
      </p>
      <h1
        style="
          margin:12px 0 0;
          font-family:var(--font-display);
          font-size:clamp(34px, 6vw, 52px);
          line-height:0.98;
          letter-spacing:-0.05em;
          color:var(--text-primary);
        "
      >
        This page wasn’t found.
      </h1>
      <p style="margin:16px 0 0;font-size:15px;line-height:1.7;color:var(--text-secondary);">
        The issue may have moved, the link may be incomplete, or the route may no longer exist. Return to Today and continue from a verified issue card.
      </p>
      <a
        href="/"
        style="
          margin-top:24px;
          min-height:48px;
          padding:0 22px;
          border-radius:999px;
          border:1px solid rgba(184, 92, 0, 0.28);
          background:rgba(210, 140, 40, 0.12);
          color:var(--score-warning);
          display:inline-flex;
          align-items:center;
          justify-content:center;
          text-decoration:none;
          font-size:13px;
          font-weight:700;
          letter-spacing:0.01em;
        "
      >
        Return to Today
      </a>
    </section>
  </main>
</Base>
