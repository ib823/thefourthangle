---
import '../../styles/global.css';
import App from '../../components/App.svelte';
import { ISSUES, opinionLabel } from '../../data/issues';

export function getStaticPaths() {
  return ISSUES.map(issue => ({
    params: { id: issue.id },
    props: { issue },
  }));
}

const { issue } = Astro.props;
const siteUrl = Astro.site?.origin || 'https://thefourthangle.pages.dev';
const issueUrl = `${siteUrl}/issue/${issue.id}`;
const ogImage = `${siteUrl}/og/issue-${issue.id}.png`;

// OG description: context + scores, optimized for social platforms (110-160 chars)
const os = issue.opinionShift;
const ns = Math.round(issue.finalScore ?? 0);
const suffix = ` — ${os}% Opinion Shift · Neutrality: ${ns}/100`;
const maxCtx = 155 - suffix.length;
let ctxTrunc = issue.context;
if (ctxTrunc.length > maxCtx) {
  ctxTrunc = ctxTrunc.substring(0, maxCtx).replace(/\s+\S*$/, '') + '...';
}
const description = ctxTrunc + suffix;
const title = `${issue.headline} — The Fourth Angle`;
const imageAlt = `${issue.headline} — ${os}% Opinion Shift · Neutrality ${ns}/100`;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta name="theme-color" content="#F8F9FA" media="(prefers-color-scheme: light)" />
  <meta name="theme-color" content="#1A1A1A" media="(prefers-color-scheme: dark)" />
  <title>{title}</title>
  <meta name="description" content={description} />

  <meta property="og:title" content={issue.headline} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:type" content="image/png" />
  <meta property="og:image:alt" content={imageAlt} />
  <meta property="og:url" content={issueUrl} />
  <meta property="og:type" content="article" />
  <meta property="og:site_name" content="The Fourth Angle" />
  <meta property="og:locale" content="en_MY" />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:site" content="@fourthangle" />
  <meta name="twitter:title" content={issue.headline} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />
  <meta name="twitter:image:alt" content={imageAlt} />

  <meta name="author" content="The Fourth Angle" />
  <meta property="article:published_time" content={issue.sourceDate ? `${issue.sourceDate}T08:00:00+08:00` : ''} />
  <meta property="article:section" content="Analysis" />
  <link rel="canonical" href={issueUrl} />
  <meta name="mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <link rel="manifest" href="/manifest.json" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/png" href="/favicon.png?v=6" />
  <link rel="apple-touch-icon" href="/icons/apple-touch-icon.png" />
</head>
<body>
  <a href="#main-content" class="sr-only">Skip to content</a>
  <div id="main-content">
    <App client:load initialIssueId={issue.id} />
  </div>
  <script>
    if ('serviceWorker' in navigator) {
      navigator.serviceWorker.register('/sw.js').catch(() => {});
    }
  </script>
</body>
</html>
