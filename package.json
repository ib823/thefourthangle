{
  "name": "fourth-angle",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "generate-og": "node scripts/generate-og-images.mjs",
    "validate": "node scripts/validate-issues.mjs",
    "build-graph": "node scripts/build-fact-graph.mjs",
    "build": "rm -rf dist && node scripts/validate-issues.mjs && node scripts/check-font-budget.mjs && node scripts/check-storage-keys.mjs && node scripts/build-issues-json.mjs && node scripts/build-sitemap.mjs && node scripts/build-fact-graph.mjs && node scripts/sign-content.mjs && node scripts/build-verifier.mjs && node scripts/build-search-index.mjs && node scripts/generate-image-sizes.mjs && node scripts/generate-og-images.mjs && astro build && node scripts/stealth.mjs && node scripts/build-csp-hashes.mjs",
    "check-signatures": "node scripts/check-signatures.mjs",
    "check-fonts": "node scripts/check-font-budget.mjs",
    "check-bundle": "node scripts/check-bundle-budget.mjs",
    "check-storage-keys": "node scripts/check-storage-keys.mjs",
    "preview": "astro preview",
    "test": "vitest run",
    "lint": "biome lint",
    "lint:fix": "biome lint --write",
    "check": "astro check",
    "e2e": "playwright test",
    "e2e:chromium": "playwright test --project=chromium-desktop --project=chromium-mobile --project=chromium-tablet",
    "e2e:ci": "playwright test --project=chromium-desktop",
    "astro": "astro",
    "sign": "node scripts/sign-content.mjs"
  },
  "dependencies": {
    "@astrojs/svelte": "^8.0.3",
    "@nanostores/persistent": "^1.3.3",
    "@tailwindcss/vite": "^4.2.2",
    "astro": "^6.0.8",
    "minisearch": "^7.2.0",
    "nanostores": "^1.2.0",
    "svelte": "^5.54.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@axe-core/playwright": "^4.11.2",
    "@biomejs/biome": "2.4.12",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "canvas": "^3.2.3",
    "sharp": "^0.33.0",
    "vitest": "^3.1.1"
  }
}
