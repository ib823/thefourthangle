# build output
dist/
# generated types
.astro/

# dependencies
node_modules/

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*


# environment variables
.env
.env.production

# signing keys
.keys/

# macOS-specific files
.DS_Store

# operational security — never commit
*opsec*
*stealth-guide*
*build-prompt*
claude-code-build-prompt.md
fourth-angle-zero-cost-stealth-guide.md
addendum-no-ai-references.md

# IDE / workspace
.vscode/

# temporary images / screenshots
*.png
*.jpg
*.jpeg
!public/**/*.png
!logo-concepts/**/*.png

# OG images (generated during build, not source files)
public/og/*.png
public/og/prompts.json

# Responsive image variants (generated during build)
public/images/issues/

# audit reports (one-time, work is done)
audit/

# jetbrains setting folder
.idea/

# Cloudflare Wrangler local state — contains account-scoped IDs
.wrangler/
workers/**/.wrangler/

# Radar output — only commit state, queue, health, last-cycle log
radar/output/logs/*.log
!radar/output/logs/last-cycle.log
radar/output/archive/
__pycache__/
*.pyc
.pytest_cache/
