/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  X-XSS-Protection: 0
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), interest-cohort=(), accelerometer=(), gyroscope=(), magnetometer=(), payment=(), usb=(), display-capture=()
  Content-Security-Policy: default-src 'self'; script-src 'self' CSP_SCRIPT_HASHES; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self' https://tfa-notify.4thangle.workers.dev https://tfa-sync.4thangle.workers.dev; object-src 'none'; worker-src 'self'; manifest-src 'self'; frame-ancestors 'self'; base-uri 'self'; form-action 'self'; upgrade-insecure-requests; report-uri https://tfa-notify.4thangle.workers.dev/api/csp-report
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: cross-origin
  Cross-Origin-Embedder-Policy: credentialless

/*.html
  Cache-Control: no-store, max-age=0, must-revalidate

/
  Cache-Control: no-store, max-age=0, must-revalidate

/issue/*
  Cache-Control: no-store, max-age=0, must-revalidate

/about
  Cache-Control: no-store, max-age=0, must-revalidate

/disclaimer
  Cache-Control: no-store, max-age=0, must-revalidate

/verify
  Cache-Control: no-store, max-age=0, must-revalidate

/verify.html
  Cache-Control: no-store, max-age=0, must-revalidate

/sw.js
  Cache-Control: no-store, max-age=0, must-revalidate

/offline.html
  Cache-Control: no-store, max-age=0, must-revalidate

/manifest.json
  Cache-Control: no-store, max-age=0, must-revalidate

/favicon.svg
  Cache-Control: no-store, max-age=0, must-revalidate

/favicon.png
  Cache-Control: no-store, max-age=0, must-revalidate

/icons/*
  Cache-Control: no-store, max-age=0, must-revalidate

/screenshots/*
  Cache-Control: no-store, max-age=0, must-revalidate

/issues-feed.json
  Cache-Control: no-store, max-age=0, must-revalidate

/issues/*
  Cache-Control: no-store, max-age=0, must-revalidate

/fact-graph.json
  Cache-Control: no-store, max-age=0, must-revalidate

/search-index.json
  Cache-Control: no-store, max-age=0, must-revalidate

/signatures.json
  Cache-Control: no-store, max-age=0, must-revalidate

/pubkey.pem
  Cache-Control: no-store, max-age=0, must-revalidate

/.well-known/*
  Cache-Control: public, max-age=86400

/_a/*
  Cache-Control: public, max-age=31536000, immutable

/fonts/*
  Cache-Control: public, max-age=31536000, immutable

/og/*
  Cache-Control: no-store, max-age=0, must-revalidate
  Cross-Origin-Resource-Policy: cross-origin
  Access-Control-Allow-Origin: *

/og/backgrounds/*
  Cache-Control: no-store, max-age=0, must-revalidate
  Cross-Origin-Resource-Policy: cross-origin
  Access-Control-Allow-Origin: *

/og-image.png
  Cache-Control: no-store, max-age=0, must-revalidate
  Cross-Origin-Resource-Policy: cross-origin
  Access-Control-Allow-Origin: *
